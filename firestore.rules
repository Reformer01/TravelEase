rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VOYAGEFLOW SECURITY RULES - PROTOTYPING PHASE
     * 
     * Core Philosophy:
     * This ruleset enforces a strict user-ownership model. Every piece of data in the system 
     * is tied to a specific Firebase Authentication UID. Authorization is primarily path-based, 
     * ensuring that users can only access data nested within their own /users/{userId} tree.
     * 
     * Data Structure:
     * The hierarchy is strictly organized by user:
     * - /users/{userId}/profile: Personal profile information.
     * - /users/{userId}/bookings/{bookingId}: High-level booking summaries.
     * - /users/{userId}/bookings/{bookingId}/bookingItems/{bookingItemId}: Individual travel segments.
     * 
     * Key Security Decisions:
     * 1. Authorization Independence: To ensure rules are performant and cost-effective, we avoid
     *    using get() or exists() calls to check parent documents.
     * 2. Denormalization for Authorization: The `userId` field is denormalized (copied) into 
     *    Booking and BookingItem documents. This allows rules to verify ownership directly 
     *    against the document being accessed.
     * 3. Flexible Prototyping: While ownership is strictly enforced, the rules do not 
     *    validate the specific shape or data types of content fields, allowing for rapid 
     *    schema iteration during development.
     * 4. Relational Integrity: On creation and update, the rules enforce that internal 
     *    ownership fields (like userId or id) match the path and remain immutable.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Verifies the user is the owner and the document exists.
     * Used for update and delete operations to prevent orphaned or invalid requests.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the UserProfile document. Each user has exactly one profile.
     * @path /users/{userId}/profile
     * @allow (get) If the authenticated user's UID matches the {userId} in the path.
     * @deny (create) If the 'id' field in the data does not match the {userId} in the path.
     * @principle Path-based ownership with internal ID consistency check.
     */
    match /users/{userId}/profile {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for Bookings. Access is restricted to the user who created the booking.
     * @path /users/{userId}/bookings/{bookingId}
     * @allow (list) If the authenticated user is listing their own subcollection.
     * @deny (update) If the request attempts to change the 'userId' field of an existing booking.
     * @principle Denormalized ownership validation for Authorization Independence.
     */
    match /users/{userId}/bookings/{bookingId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for BookingItems within a specific booking.
       * @path /users/{userId}/bookings/{bookingId}/bookingItems/{bookingItemId}
       * @allow (create) If the item includes the user's ID as a denormalized field.
       * @deny (get) If a user attempts to access a booking item belonging to another user's ID path.
       * @principle Deeply nested ownership verification without parent lookups.
       */
      match /bookingItems/{bookingItemId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }
    
  }
}