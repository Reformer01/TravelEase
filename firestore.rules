rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VOYAGEFLOW SECURITY RULES - PROTOTYPING MODE
     * 
     * Core Philosophy:
     * This ruleset enforces a strict user-ownership model where users have exclusive access to their 
     * own data trees. Administrative actions are managed via a dedicated 'roles_admin' collection.
     * 
     * Data Structure:
     * - User-specific data (Profiles, Bookings, Baskets, Payments) is nested under /users/{userId}.
     * - Publicly searchable content (TravelServices) resides in a top-level collection.
     * - Authorization roles (Admin) are managed in /roles_admin/{userId}.
     * 
     * Key Security Decisions:
     * 1. Path-Based Ownership: The authenticated user's UID must match the {userId} wildcard in the path.
     * 2. Denormalization for Authorization: Subcollections include the 'userId' field to allow 
     *    independent validation, though path-based rules remain the primary defense.
     * 3. Database Access Control (DBAC): Admin rights are determined by the existence of a document 
     *    in /roles_admin/{userId}, avoiding complex custom claims.
     * 4. Flexible Schema: During prototyping, only fields critical for authorization and relational 
     *    integrity (like owner IDs) are validated.
     */

    // --- Global Helper Functions ---

    /** Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks if the document exists and the current user is the owner. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** Checks if the user has a document in the roles_admin collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the UserProfile entity. Users can only read/write their own profile.
     * @path /users/{userId}
     * @allow get, list, create, update: if isOwner(userId)
     * @deny delete: if true (User profiles are persistent)
     * @principle Pattern 4 (Self-Creation) & Pattern 1 (Ownership).
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if false; // Profiles generally shouldn't be deleted by clients in this app context.

      /**
       * @description Rules for BookingBaskets. Users manage their own temporary selections.
       * @path /users/{userId}/booking_baskets/{basketId}
       * @allow create, update, delete: if isOwner(userId)
       * @principle Pattern 1 (Ownership).
       */
      match /booking_baskets/{basketId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);

        /**
         * @description Rules for individual items in a basket.
         * @path /users/{userId}/booking_baskets/{basketId}/basket_items/{basketItemId}
         * @principle Enforces path consistency via denormalized userId field.
         */
        match /basket_items/{basketItemId} {
          allow get, list: if isOwner(userId);
          // Note: userId is denormalized here for auth independence per IR requirements.
          allow create: if isOwner(userId) && request.resource.data.basketId == basketId;
          allow update: if isExistingOwner(userId) && request.resource.data.basketId == resource.data.basketId;
          allow delete: if isExistingOwner(userId);
        }
      }

      /**
       * @description Rules for confirmed Bookings. Users can view their own history.
       * @path /users/{userId}/bookings/{bookingId}
       * @principle Pattern 1 (Ownership) with restricted deletion.
       */
      match /bookings/{bookingId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if false; // Confirmed bookings usually cannot be deleted by users.

        /**
         * @description Rules for items within a confirmed booking.
         * @path /users/{userId}/bookings/{bookingId}/booking_items/{bookingItemId}
         */
        match /booking_items/{bookingItemId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.bookingId == bookingId;
          allow update: if isExistingOwner(userId) && request.resource.data.bookingId == resource.data.bookingId;
          allow delete: if false;
        }
      }

      /**
       * @description Rules for Payment records. Immutable once created for financial integrity.
       * @path /users/{userId}/payments/{paymentId}
       * @principle Ownership-based read with append-only write posture.
       */
      match /payments/{paymentId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update, delete: if false; // Payment records are immutable for audit trails.
      }
    }

    /**
     * @description Publicly searchable travel services. 
     * @path /travel_services/{travelServiceId}
     * @allow get, list: if isSignedIn()
     * @allow write: if isAdmin()
     * @principle Structural Segregation for public/global data.
     */
    match /travel_services/{travelServiceId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description System-level collection for administrative roles. 
     * @path /roles_admin/{userId}
     * @deny write: if true (Managed by server/admin SDK)
     * @principle Pattern 2 (Roles) using existence-based checks.
     */
    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false;
    }
  }
}